{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ],
    "functions": {
        "api/**/*.ts": {
            "runtime": "nodejs20.x",
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "crons": [
        {
            "path": "/api/cron-task",
            "schedule": "0 0 * * *"
        }
    ]
}